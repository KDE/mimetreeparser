@PACKAGE_INIT@
include(CMakeFindDependencyMacro)

find_dependency(
    KF6I18n
    "@KF_MIN_VERSION@"
)
if(@KF6Mime_FOUND@)
    find_dependency(
        KF6Mime
        "@KF_MIN_VERSION@"
    )
else()
    find_dependency(
        KPim6Mime
        "@KPIM_MIME_VERSION@"
    )
    if(NOT TARGET KF6::Mime)
        add_library(KF6::Mime ALIAS KPim6::Mime)
    endif()
endif()
find_dependency(
    KPim6MimeTreeParserCore
    "@PIM_VERSION@"
)

find_dependency(
    Qt6Widgets
    "@QT_REQUIRED_VERSION@"
)

include("${CMAKE_CURRENT_LIST_DIR}/KPim6MimeTreeParserWidgetsTargets.cmake")
